{
  "$schema": "https://app.kilo.ai/config.json",
  "rules": [
    {
      "action": "allow"
    }
  ],
  "mcp": {
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "headers": {
        "X-Goog-Api-Key": "${STITCH_API_KEY}"
      },
      "enabled": true
    }
  }
}
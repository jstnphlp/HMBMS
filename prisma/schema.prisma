generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STAFF
  DONOR
}

enum DonorStatus {
  ACTIVE
  INACTIVE
}

enum Program {
  SUPSUP_TODO
  MILKY_WAY
  MOMS_ACT
}

enum BatchStatus {
  POOLING
  TESTING
  PASTEURIZED
  AVAILABLE
  DISPENSED
  DISPOSED
}

enum CollectionBatchType {
  PRE_PSTR
  PSTR
  POST_PSTR
}

enum CollectionBatchStatus {
  ACTIVE
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum LabStage {
  PRE_PASTEURIZATION
  POST_PASTEURIZATION
}

enum LabTestResult {
  PASS
  FAIL
  PENDING
}

enum SmsStatus {
  PENDING
  SENT
  FAILED
}

enum CollectionStatus {
  PENDING_LAB_TEST
  READY_FOR_DISPENSING
}

enum EligibilityResult {
  PASS
  FAIL
}

enum SupsupTodoWorkflowStatus {
  IN_PROGRESS
  WAITING_PRE_LAB_RESULT
  PRE_LAB_FAILED
  READY_FOR_PASTEURIZATION
  WAITING_POST_LAB_RESULT
  POST_LAB_FAILED
  READY_FOR_STORAGE
  READY_FOR_DISPENSING
  DISPOSED
}

enum SupsupTodoWorkflowStep {
  LACTATION_EXTRACTION
  BOTTLING_LABELING
  COLD_CHAIN
  PRE_IN_COLLECTION
  PRE_SENT_TO_LAB
  PRE_LAB_RESULT
  PASTEURIZATION
  POST_SENT_TO_LAB
  POST_LAB_RESULT
  COMPLETED
  DISPOSED
}

enum MilkRequestStatus {
  DRAFT
  INCOMPLETE
  QUEUED
  READY_FOR_RELEASE
  PARTIALLY_FULFILLED
  RELEASED
  CANCELLED
}

enum MilkRequestPriority {
  URGENT
  HIGH
  NORMAL
  LOW
}

enum MilkRequestPaymentStatus {
  NOT_REQUIRED
  UNPAID
  PARTIAL
  PAID
  WAIVED
}

enum MilkRequestNotificationStatus {
  NOT_READY
  READY_FOR_PICKUP
  STAFF_NOTED
  MANUALLY_NOTIFIED
}



model User {
  user_id    Int      @id @default(autoincrement())
  auth_id    String   @unique
  email      String   @unique
  password   String?
  role       Role     @default(STAFF)
  full_name  String   @default("")
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  donors      Donor[]
  collections Collection[] @relation("RecordedBy")
  batches     Batch[]
  labResults  LabResult[]  @relation("TestedBy")
  inventory   Inventory[]
  dispensings Dispensing[]
  disposals   Disposal[]
  reports     Report[]
  auditLogs   AuditLog[]
  eligibilityUpdates DonorEligibility[] @relation("EligibilityUpdatedBy")
  supSupTodoWorkflows SupsupTodoDonationWorkflow[] @relation("SupsupWorkflowCreatedBy")
  supSupTodoWorkflowUpdates SupsupTodoDonationWorkflow[] @relation("SupsupWorkflowUpdatedBy")
  collectionBatches CollectionBatch[] @relation("CollectionBatchCreatedBy")
  createdMilkRequests MilkRequest[] @relation("MilkRequestCreatedBy")
  releasedMilkRequests MilkRequest[] @relation("MilkRequestReleasedBy")
  milkRequestAllocations MilkRequestAllocation[] @relation("MilkRequestAllocationCreatedBy")
}

model Donor {
  donor_id            Int         @id @default(autoincrement())
  user_id             Int
  first_name          String
  middle_name         String?
  last_name           String
  birthdate           DateTime
  address             String
  contact_no          String
  civil_status        String
  religion            String?
  occupation          String?
  spouse_name         String?
  spouse_occupation   String?
  spouse_contact_no   String?
  delivery_date       DateTime?
  delivery_place      String?
  delivery_type       String?
  aog                 String?
  pregnancy_delivery_details String?
  infant_name         String?
  infant_birthdate    DateTime?
  infant_sex          String?
  infant_birth_weight String?
  infant_details      String?
  status              DonorStatus @default(ACTIVE)
  registration        DateTime    @default(now())

  user        User         @relation(fields: [user_id], references: [user_id])
  collections Collection[]
  eligibility DonorEligibility?
  supSupTodoWorkflows SupsupTodoDonationWorkflow[]
}

model Beneficiary {
  beneficiary_id Int     @id @default(autoincrement())
  recipient_id   Int?
  name           String
  contact_no     String
  birthdate      DateTime?
  sex            String?
  birth_weight   String?
  gestational_age String?
  medical_condition String?
  notes          String?
  remarks        String?
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now()) @updatedAt

  recipient    Recipient?    @relation(fields: [recipient_id], references: [recipient_id])
  milkRequests MilkRequest[]
  dispensings  Dispensing[]
  sms          SMS[]

  @@index([recipient_id])
}

model Recipient {
  recipient_id                 Int      @id @default(autoincrement())
  first_name                   String
  middle_name                  String?
  last_name                    String
  contact_no                   String
  address                      String
  relationship_to_beneficiary  String
  notes                        String?
  status                       String   @default("ACTIVE")
  created_at                   DateTime @default(now())
  updated_at                   DateTime @updatedAt

  beneficiaries Beneficiary[]
  milkRequests  MilkRequest[]
  sms           SMS[]
}

model Collection {
  ctn             Int              @id @default(autoincrement())
  tracking_no     String?          @unique
  donor_id        Int
  recorded_by     Int
  program         Program
  collection_date DateTime
  volume          Float
  remarks         String?
  is_pasteurized  Boolean          @default(false)
  status          CollectionStatus @default(PENDING_LAB_TEST)
  batch_no        String?
  bottle_no       String?          @unique
  expiration_date DateTime?
  dtn             String?
  aob             String?
  collected_by    String?
  batch_id        Int?

  donor    Donor  @relation(fields: [donor_id], references: [donor_id])
  recorder User   @relation("RecordedBy", fields: [recorded_by], references: [user_id])
  batch    Batch? @relation(fields: [batch_id], references: [batch_id])
  supSupTodoWorkflow SupsupTodoDonationWorkflow?
  collectionBatchItems CollectionBatchItem[]
}

model Batch {
  batch_id     Int         @id @default(autoincrement())
  batch_code   String      @unique
  pooling_date DateTime
  total_volume Float
  remaining_volume Float  @default(0)
  status       BatchStatus @default(POOLING)
  created_by   Int
  created_at   DateTime    @default(now())

  creator     User         @relation(fields: [created_by], references: [user_id])
  collections Collection[]
  labResults  LabResult[]
  inventory   Inventory?
  dispensings Dispensing[]
  disposals   Disposal[]
  supSupTodoWorkflow SupsupTodoDonationWorkflow?
  milkRequestAllocations MilkRequestAllocation[]
}

model DonorEligibility {
  eligibility_id  Int                @id @default(autoincrement())
  donor_id        Int                @unique
  screening_result EligibilityResult?
  screening_date  DateTime?
  consent_signed  Boolean            @default(false)
  consent_date    DateTime?
  staff_notes     String?
  updated_by      Int?
  created_at      DateTime           @default(now())
  updated_at      DateTime           @updatedAt

  donor   Donor @relation(fields: [donor_id], references: [donor_id])
  updater User? @relation("EligibilityUpdatedBy", fields: [updated_by], references: [user_id])
}

model SupsupTodoDonationWorkflow {
  workflow_id       Int                    @id @default(autoincrement())
  donor_id          Int
  program           Program                @default(SUPSUP_TODO)
  tracking_no       String                 @unique
  sample_sequence   Int
  ctn               Int?                   @unique
  batch_id          Int?                   @unique
  final_status      SupsupTodoWorkflowStatus @default(IN_PROGRESS)
  current_step      SupsupTodoWorkflowStep @default(LACTATION_EXTRACTION)

  extraction_completed_at DateTime?
  extracted_volume        Float?
  extraction_notes         String?

  bottling_completed_at DateTime?
  bottle_no             String?
  label_confirmed       Boolean @default(false)
  bottling_notes         String?

  cold_chain_started_at DateTime?
  placed_in_cooler      Boolean @default(false)
  cold_chain_notes       String?

  pre_collection_confirmed Boolean @default(false)
  pre_sample_volume        Float?
  pre_in_collection_notes  String?
  pre_sent_to_lab          Boolean @default(false)
  pre_sample_sent_at       DateTime?
  pre_expected_result_date DateTime?
  pre_sent_notes           String?
  pre_lab_result           LabTestResult?
  pre_lab_received_at      DateTime?
  pre_lab_notes            String?

  pasteurization_completed_at DateTime?
  pasteurization_confirmed    Boolean @default(false)
  pasteurization_notes        String?

  post_sample_volume        Float?
  post_sent_to_lab          Boolean @default(false)
  post_sample_sent_at       DateTime?
  post_expected_result_date DateTime?
  post_sent_notes           String?
  post_lab_result           LabTestResult?
  post_lab_received_at      DateTime?
  post_lab_notes            String?

  created_by Int
  updated_by Int?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  donor      Donor       @relation(fields: [donor_id], references: [donor_id])
  collection Collection? @relation(fields: [ctn], references: [ctn])
  batch      Batch?      @relation(fields: [batch_id], references: [batch_id])
  creator    User        @relation("SupsupWorkflowCreatedBy", fields: [created_by], references: [user_id])
  updater    User?       @relation("SupsupWorkflowUpdatedBy", fields: [updated_by], references: [user_id])
  collectionBatchItems CollectionBatchItem[]

  @@unique([donor_id, sample_sequence])
}

model CollectionBatch {
  id         Int                   @id @default(autoincrement())
  batch_no   String                @unique
  batch_type CollectionBatchType
  status     CollectionBatchStatus @default(ACTIVE)
  created_by Int
  created_at DateTime              @default(now())
  updated_at DateTime              @updatedAt
  notes      String?

  creator User                  @relation("CollectionBatchCreatedBy", fields: [created_by], references: [user_id])
  items   CollectionBatchItem[]

  @@index([batch_type, status])
}

model CollectionBatchItem {
  id            Int      @id @default(autoincrement())
  batch_id      Int
  collection_id Int
  workflow_id   Int?
  ctn           String
  created_at    DateTime @default(now())

  batch      CollectionBatch @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  collection Collection      @relation(fields: [collection_id], references: [ctn])
  workflow   SupsupTodoDonationWorkflow? @relation(fields: [workflow_id], references: [workflow_id])

  @@unique([batch_id, collection_id])
  @@index([collection_id])
  @@index([workflow_id])
}

model LabResult {
  lab_id       Int           @id @default(autoincrement())
  batch_id     Int
  stage        LabStage
  test_date    DateTime
  result       LabTestResult @default(PENDING)
  tested_by    Int
  colony_count Int?
  remarks      String?

  batch  Batch @relation(fields: [batch_id], references: [batch_id])
  tester User  @relation("TestedBy", fields: [tested_by], references: [user_id])
}

model Inventory {
  inv_id          Int      @id @default(autoincrement())
  batch_id        Int      @unique
  donated_vol     Float
  pasteurized_vol Float
  available_vol   Float
  last_updated    DateTime @updatedAt
  updated_by      Int

  batch   Batch @relation(fields: [batch_id], references: [batch_id])
  updater User  @relation(fields: [updated_by], references: [user_id])
}

model MilkRequest {
  request_id            Int                           @id @default(autoincrement())
  request_no            String                        @unique
  recipient_id          Int
  beneficiary_id        Int
  status                MilkRequestStatus             @default(DRAFT)
  priority              MilkRequestPriority           @default(NORMAL)
  requested_volume      Float
  allocated_volume      Float                         @default(0)
  released_volume       Float                         @default(0)
  reason                String
  needed_by             DateTime?
  payment_status        MilkRequestPaymentStatus      @default(UNPAID)
  deposit_amount        Float?
  price_per_ml          Float?
  total_amount          Float?
  amount_paid           Float?
  payment_notes         String?
  notification_status   MilkRequestNotificationStatus @default(NOT_READY)
  profile_complete      Boolean                       @default(false)
  beneficiary_complete  Boolean                       @default(false)
  reason_provided       Boolean                       @default(false)
  volume_entered        Boolean                       @default(false)
  staff_approved        Boolean                       @default(false)
  payment_reviewed      Boolean                       @default(false)
  remarks               String?
  cancellation_reason   String?
  cancelled_at          DateTime?
  created_by            Int
  created_at            DateTime                      @default(now())
  updated_at            DateTime                      @updatedAt
  released_by           Int?
  released_at           DateTime?

  recipient    Recipient               @relation(fields: [recipient_id], references: [recipient_id])
  beneficiary  Beneficiary             @relation(fields: [beneficiary_id], references: [beneficiary_id])
  creator      User                    @relation("MilkRequestCreatedBy", fields: [created_by], references: [user_id])
  releaser     User?                   @relation("MilkRequestReleasedBy", fields: [released_by], references: [user_id])
  allocations  MilkRequestAllocation[]
  dispensings  Dispensing[]
  sms          SMS[]

  @@index([recipient_id])
  @@index([beneficiary_id])
  @@index([status, priority, created_at])
  @@index([payment_status])
}

model MilkRequestAllocation {
  allocation_id   Int      @id @default(autoincrement())
  request_id      Int
  batch_id        Int
  volume          Float
  released_volume Float    @default(0)
  status          String   @default("ALLOCATED")
  allocated_by    Int
  allocated_at    DateTime @default(now())
  released_at     DateTime?

  request   MilkRequest @relation(fields: [request_id], references: [request_id], onDelete: Cascade)
  batch     Batch       @relation(fields: [batch_id], references: [batch_id])
  allocator User        @relation("MilkRequestAllocationCreatedBy", fields: [allocated_by], references: [user_id])

  @@unique([request_id, batch_id])
  @@index([batch_id])
  @@index([status])
}

model Dispensing {
  dis_id          Int      @id @default(autoincrement())
  batch_id        Int
  beneficiary_id  Int
  milk_request_id Int?
  dispensed_by    Int
  dispensing_date DateTime
  volume          Float
  price           Float
  total           Float
  payment_status  MilkRequestPaymentStatus?
  amount_paid     Float?
  source_summary  String?
  remarks         String?

  batch       Batch       @relation(fields: [batch_id], references: [batch_id])
  beneficiary Beneficiary @relation(fields: [beneficiary_id], references: [beneficiary_id])
  milkRequest MilkRequest? @relation(fields: [milk_request_id], references: [request_id])
  dispenser   User        @relation(fields: [dispensed_by], references: [user_id])

  @@index([milk_request_id])
}

model Disposal {
  disposal_id   Int      @id @default(autoincrement())
  batch_id      Int
  disposal_date DateTime
  reason        String
  volume        Float
  disposed_by   Int
  remarks       String?

  batch    Batch @relation(fields: [batch_id], references: [batch_id])
  disposer User  @relation(fields: [disposed_by], references: [user_id])
}

model SMS {
  sms_id         Int       @id @default(autoincrement())
  beneficiary_id Int
  recipient_id   Int?
  milk_request_id Int?
  phone_number   String?
  message        String
  status         SmsStatus @default(PENDING)
  provider       String    @default("MANUAL")
  notification_type String?
  error_message  String?
  scheduled_at   DateTime
  sent_at        DateTime?
  retry          Int       @default(0)

  beneficiary Beneficiary @relation(fields: [beneficiary_id], references: [beneficiary_id])
  recipient   Recipient?  @relation(fields: [recipient_id], references: [recipient_id])
  milkRequest MilkRequest? @relation(fields: [milk_request_id], references: [request_id])

  @@index([milk_request_id, provider, notification_type, status])
  @@index([recipient_id])
}

model AuditLog {
  log_id         Int      @id @default(autoincrement())
  user_id        Int
  action_date    DateTime @default(now())
  action_details String

  user User @relation(fields: [user_id], references: [user_id])
}

model Report {
  report_id    Int      @id @default(autoincrement())
  report_code  String   @unique
  type         String
  period       String?
  report_title String?
  program      Program?
  date_from    DateTime
  date_to      DateTime
  data         Json?
  generated_at DateTime @default(now())
  generated_by Int

  user User @relation(fields: [generated_by], references: [user_id])
}
